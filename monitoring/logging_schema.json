{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Monitoring Log Schema",
    "description": "Logging schema for AI-Generated Image Risk Assessment API",
    "version": "1.0.0",
    "definitions": {
        "request_log": {
            "type": "object",
            "required": [
                "timestamp",
                "request_id",
                "endpoint",
                "method",
                "status_code",
                "latency_ms",
                "model_version",
                "semantic_version",
                "api_version"
            ],
            "properties": {
                "timestamp": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 timestamp"
                },
                "request_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique request identifier"
                },
                "endpoint": {
                    "type": "string",
                    "enum": [
                        "/analyze/image",
                        "/health",
                        "/capabilities"
                    ],
                    "description": "API endpoint called"
                },
                "method": {
                    "type": "string",
                    "enum": [
                        "GET",
                        "POST"
                    ],
                    "description": "HTTP method"
                },
                "status_code": {
                    "type": "integer",
                    "minimum": 100,
                    "maximum": 599,
                    "description": "HTTP response status code"
                },
                "latency_ms": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Request latency in milliseconds"
                },
                "model_version": {
                    "type": "string",
                    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
                    "description": "Model version (semver)"
                },
                "semantic_version": {
                    "type": "string",
                    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
                    "description": "Semantic version (semver)"
                },
                "api_version": {
                    "type": "string",
                    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
                    "description": "API version (semver)"
                },
                "input": {
                    "type": "object",
                    "properties": {
                        "resolution_bucket": {
                            "type": "string",
                            "enum": [
                                "small",
                                "medium",
                                "large",
                                "xlarge"
                            ],
                            "description": "Image resolution bucket (NO actual resolution logged)"
                        },
                        "filesize_bucket": {
                            "type": "string",
                            "enum": [
                                "tiny",
                                "small",
                                "medium",
                                "large"
                            ],
                            "description": "File size bucket (NO actual size logged)"
                        },
                        "format": {
                            "type": "string",
                            "enum": [
                                "jpeg",
                                "png",
                                "webp"
                            ],
                            "description": "Image format"
                        }
                    },
                    "description": "Input metadata (NO image content)"
                },
                "output": {
                    "type": "object",
                    "properties": {
                        "probability_bucket": {
                            "type": "string",
                            "enum": [
                                "low",
                                "borderline",
                                "high"
                            ],
                            "description": "Probability range bucket"
                        },
                        "probability_decile": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9,
                            "description": "Probability decile (0-9)"
                        },
                        "confidence_width_bucket": {
                            "type": "string",
                            "enum": [
                                "narrow",
                                "medium",
                                "wide"
                            ],
                            "description": "Confidence interval width bucket"
                        },
                        "interpretation": {
                            "type": "string",
                            "description": "Interpretation label from API"
                        }
                    },
                    "description": "Output metadata (NO exact probability)"
                },
                "client": {
                    "type": "object",
                    "properties": {
                        "ip_hash": {
                            "type": "string",
                            "pattern": "^sha256:[a-f0-9]{64}$",
                            "description": "SHA-256 hash of client IP (NOT raw IP)"
                        },
                        "rate_1min": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Client request rate in last 1 minute"
                        }
                    },
                    "description": "Client metadata (privacy-preserving)"
                },
                "flags": {
                    "type": "object",
                    "properties": {
                        "borderline": {
                            "type": "boolean",
                            "description": "Result was in borderline range"
                        },
                        "high_rate_client": {
                            "type": "boolean",
                            "description": "Client exceeded rate threshold"
                        },
                        "timeout": {
                            "type": "boolean",
                            "description": "Request timed out"
                        }
                    },
                    "description": "Signal flags"
                }
            }
        },
        "error_log": {
            "type": "object",
            "required": [
                "timestamp",
                "request_id",
                "endpoint",
                "status_code",
                "error_type"
            ],
            "properties": {
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                },
                "request_id": {
                    "type": "string",
                    "format": "uuid"
                },
                "endpoint": {
                    "type": "string"
                },
                "method": {
                    "type": "string"
                },
                "status_code": {
                    "type": "integer"
                },
                "latency_ms": {
                    "type": "number"
                },
                "error_type": {
                    "type": "string",
                    "enum": [
                        "INVALID_CONTENT_TYPE",
                        "FILE_TOO_LARGE",
                        "RESOLUTION_TOO_HIGH",
                        "IMAGE_DECODE_ERROR",
                        "FEATURE_EXTRACTION_ERROR",
                        "INFERENCE_ERROR",
                        "TIMEOUT",
                        "INTERNAL_ERROR"
                    ],
                    "description": "Error classification"
                },
                "error_message": {
                    "type": "string",
                    "description": "User-facing error message (NO internals)"
                },
                "model_version": {
                    "type": "string"
                },
                "input": {
                    "type": "object",
                    "description": "Input metadata if available"
                },
                "client": {
                    "type": "object",
                    "properties": {
                        "ip_hash": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "health_log": {
            "type": "object",
            "required": [
                "timestamp",
                "endpoint",
                "status_code",
                "service_status",
                "model_loaded"
            ],
            "properties": {
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                },
                "endpoint": {
                    "type": "string",
                    "const": "/health"
                },
                "status_code": {
                    "type": "integer"
                },
                "service_status": {
                    "type": "string",
                    "enum": [
                        "healthy",
                        "degraded",
                        "unhealthy"
                    ]
                },
                "model_loaded": {
                    "type": "boolean"
                },
                "uptime_seconds": {
                    "type": "number"
                },
                "model_version": {
                    "type": "string"
                }
            }
        }
    },
    "prohibited_fields": {
        "description": "Fields that MUST NOT be logged",
        "fields": [
            "image_content",
            "image_pixels",
            "filename",
            "exif_data",
            "user_identity",
            "raw_ip_address",
            "exact_probability",
            "exact_resolution",
            "exact_filesize"
        ]
    },
    "bucket_definitions": {
        "resolution_buckets": {
            "small": "< 256px",
            "medium": "256px - 512px",
            "large": "512px - 1024px",
            "xlarge": "> 1024px"
        },
        "filesize_buckets": {
            "tiny": "< 100KB",
            "small": "100KB - 1MB",
            "medium": "1MB - 5MB",
            "large": "5MB - 10MB"
        },
        "probability_buckets": {
            "low": "0% - 30%",
            "borderline": "30% - 70%",
            "high": "70% - 100%"
        },
        "confidence_width_buckets": {
            "narrow": "< 0.10",
            "medium": "0.10 - 0.20",
            "wide": "> 0.20"
        }
    }
}